# Secrets — never commit
*.key
*.rosenpass-secret
*.p12
*.mobileprovision

# iOS build-time secrets (CLOAK_BOOTSTRAP_KEY, etc). Wired into the
# Xcode project as baseConfigurationReference. The .example template
# IS committed so contributors know the format; the real file is not.
clients/ios/CloakVPN/Secrets.xcconfig
!clients/ios/CloakVPN/Secrets.xcconfig.example

# Peer configuration files — contain real WireGuard private keys + rosenpass
# secret keys generated by server/scripts/add-peer.sh. Pattern catches both
# `_peer-config.txt` (full PQC config, ~1.4 MB) and `_peer-config-wg-only.txt`
# (classical fallback). Leading underscore is the working convention so a
# `git status` always surfaces these as untracked rather than tracked.
_peer-config*.txt
_peer-config*.ini
**/iphone-prod-*.config.ini
**/iphone-prod-*.config.txt

# iOS
clients/ios/*.xcodeproj/xcuserdata/
clients/ios/*.xcworkspace/xcuserdata/
clients/ios/DerivedData/
clients/ios/build/
clients/ios/.swiftpm/

# Android
clients/android/.gradle/
clients/android/build/
clients/android/app/build/
clients/android/local.properties
clients/android/.idea/
clients/android/*.iml
clients/android/captures/

# Rust / Rosenpass build artifacts
target/
*.so
!app/src/main/jniLibs/**/*.so

# macOS / editor cruft
.DS_Store
*.swp
.vscode/
.idea/

# Wrangler (Cloudflare Pages deploy CLI — local cache only)
.wrangler/

# Node (for future build steps)
node_modules/
