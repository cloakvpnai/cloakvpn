<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Alternate app icons. The primary icon (CLOAKVPN logo without
		"PRO") lives in Assets.xcassets/AppIcon.appiconset and is what
		the app shows by default. The "Pro" variant is registered here
		as a CFBundleAlternateIcons entry so we can switch to it at
		runtime via UIApplication.setAlternateIconName("CloakProIcon")
		when the user upgrades their subscription.

		File-naming convention: iOS auto-resolves @2x and @3x suffixes,
		so we ship CloakProIcon.png / @2x / @3x as loose PNGs in the
		bundle (NOT in the asset catalog — Apple's required pattern
		for alternate icons since iOS 11).

		UIPrerenderedIcon=true: the source PNGs already have the dark
		matte background baked in; we don't want iOS to apply its
		default gloss-overlay on top of them.
	-->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>CloakProIcon</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>CloakProIcon</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!--
		App Transport Security exceptions for the Cloak provisioning
		API endpoints. Each region currently runs cloak-api-server.py on
		plain HTTP (port 8443). iOS 9+ blocks plain HTTP by default;
		without these exceptions, every region-tap from the customer's
		flag strip fails with "App Transport Security policy requires
		the use of a secure connection."

		Production deploy plan: terminate TLS via nginx + Let's Encrypt
		on each region (e.g. cloak-us-west-1.cloakvpn.ai → :443) and
		drop these exceptions in favor of standard HTTPS. Until then we
		whitelist the four region IPs explicitly so we don't open the
		barn door (NSAllowsArbitraryLoads=true) for arbitrary HTTP.

		Per-IP whitelist is App Store-review friendly; the alternative
		(NSAllowsArbitraryLoads) flags reviewers and requires written
		justification.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>5.78.203.171</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>5.161.198.227</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>91.98.65.98</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>204.168.252.70</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
