// Cloak VPN — local secrets configuration (template).
//
// COPY this file to `Secrets.xcconfig` and fill in real values.
// `Secrets.xcconfig` is in `.gitignore` — it must NEVER be committed.
//
// To wire this into your build:
//   1. Open CloakVPN.xcodeproj in Xcode
//   2. Click the project in the navigator
//   3. Select the CloakVPN target -> Info tab -> Configurations
//   4. For both Debug and Release, set "Based on Configuration File"
//      to "Secrets" (the file you just copied + filled in)
//   5. Build — the `CLOAK_BOOTSTRAP_KEY` value is now visible to
//      Region.swift via Bundle.main.infoDictionary.
//
// On a fresh clone the project will fail to build until you create
// Secrets.xcconfig from this template — that's deliberate; it forces
// every operator to consciously paste the live key rather than have
// it sitting in source control.

// Bootstrap key — must match /etc/cloak/bootstrap-key on every region.
// Generate with: openssl rand -base64 32
// Last rotated: 2026-04-27 (after public repo audit)
CLOAK_BOOTSTRAP_KEY = REPLACE_WITH_BOOTSTRAP_KEY_FROM_PASSWORD_MANAGER

// Cross-reference: server-side counterpart at /etc/cloak/bootstrap-key
// on each of the 4 regions (us-west-1, us-east-1, de1, fi1). To rotate,
// generate a new key, scp to all 4 regions' /etc/cloak/bootstrap-key,
// systemctl restart cloak-api-server on each, then update this file
// and ship a new TestFlight / App Store build.
