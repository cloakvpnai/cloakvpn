# Gradle / Android build artifacts
.gradle/
build/
app/build/
captures/
.cxx/

# Local machine-specific SDK path
local.properties

# IDE
.idea/
*.iml
.kotlin/

# macOS
.DS_Store

# Keystore — never commit signing keys
*.jks
*.keystore
!debug.keystore

# NDK / Rust intermediate
app/src/main/jniLibs/*/lib*.so.tmp

# The repo-root .gitignore has a global `*.so` rule. The rosenpass
# native libraries under jniLibs ARE intentionally committed (so a
# fresh checkout builds a complete APK without the full Rust+NDK
# chain), so re-include them here. Regenerate via
# Scripts/build-rosenpass-android.sh.
!app/src/main/jniLibs/**/librosenpassffi.so
