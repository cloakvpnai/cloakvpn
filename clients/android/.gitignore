# Gradle / Android build artifacts
.gradle/
build/
app/build/
captures/
.cxx/

# Local machine-specific SDK path
local.properties

# Build secrets (bootstrap key) — never commit; see secrets.properties.example
secrets.properties

# IDE
.idea/
*.iml
.kotlin/

# macOS
.DS_Store

# Keystore — never commit signing keys
*.jks
*.keystore
!debug.keystore

# NDK / Rust intermediate
app/src/main/jniLibs/*/lib*.so.tmp

# Scratch dir for the libwg-go native build (clone + Go toolchain).
.libwg-go-build/

# The repo-root .gitignore has a global `*.so` rule. The native
# libraries under jniLibs ARE intentionally committed (so a fresh
# checkout builds a complete APK without the full native toolchain),
# so re-include them here.
#   librosenpassffi.so — regenerate via Scripts/build-rosenpass-android.sh
#   libwg-go.so        — regenerate via Scripts/build-libwg-go-android.sh
!app/src/main/jniLibs/**/librosenpassffi.so
!app/src/main/jniLibs/**/libwg-go.so
