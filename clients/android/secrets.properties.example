# Lattice VPN — Android build secrets (template).
#
# COPY this file to `secrets.properties` and fill in the real value.
# `secrets.properties` is gitignored and must NEVER be committed.
#
# app/build.gradle.kts reads this at build time and exposes the value
# as BuildConfig.CLOAK_BOOTSTRAP_KEY. The Android counterpart of the
# iOS Secrets.xcconfig -> Info.plist path.
#
# CLOAK_BOOTSTRAP_KEY must match clients/ios/CloakVPN/Secrets.xcconfig
# and /etc/cloak/bootstrap-key on every region server.

CLOAK_BOOTSTRAP_KEY=replace-with-live-bootstrap-key

# ---- Release signing (Google Play) ------------------------------------
# Needed only to build a SIGNED release bundle (./gradlew :app:bundleRelease).
# Leave these blank for debug builds — the release build then stays unsigned.
#
# Generate the upload keystore ONCE:
#
#   keytool -genkey -v -keystore lattice-release.jks \
#       -keyalg RSA -keysize 4096 -validity 10000 -alias lattice
#
# Back the .jks file up somewhere safe — losing it means you can never
# ship an update to the app again. Keep it out of git (*.jks is ignored).
# RELEASE_STORE_FILE may be an absolute path or relative to clients/android/.
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=lattice
RELEASE_KEY_PASSWORD=
