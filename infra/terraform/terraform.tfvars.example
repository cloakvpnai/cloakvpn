# Copy to terraform.tfvars and fill in.
# terraform.tfvars is in .gitignore — never commit this file with a real token.

# Get your token from: https://console.hetzner.cloud → (project) → Security → API Tokens → Generate
# Scope: Read & Write (Terraform needs to create resources).
hcloud_token = "REPLACE_WITH_HETZNER_API_TOKEN"

# Hostname — becomes the Hetzner label. Also used as the DNS subdomain you'll
# point at the box (e.g. fi1.cloakvpn.ai).
server_name = "cloak-fi1"

# Recommended: hel1 (Helsinki, outside 14 Eyes).
# Alternatives: fsn1 (Falkenstein DE), nbg1 (Nuremberg DE), ash (Ashburn US),
#               hil (Hillsboro US), sin (Singapore).
location = "hel1"

# CX23 = Hetzner's current small Intel type (replaces CX22 retired in 2025/26).
# ~2 vCPU / 4GB / 40GB / 20TB out, similar price. Fine for hundreds of peers.
# If this errors with "server type ... not found" in your location, query
# https://api.hetzner.cloud/v1/server_types with your API token to see what's
# currently available.
server_type = "cx23"

# Ubuntu 24.04 is what server/scripts/setup.sh is tested against.
image = "ubuntu-24.04"

# Generate a dedicated key for this project:
#   ssh-keygen -t ed25519 -C cloakvpn -f ~/.ssh/cloakvpn_ed25519
ssh_public_key_path = "~/.ssh/cloakvpn_ed25519.pub"

# Lock SSH to your admin IP(s). Find yours with `curl ifconfig.me`.
# LEAVING THIS AS 0.0.0.0/0 IS NOT A SECURITY CATASTROPHE (SSH is key-only, port 22,
# fail2ban enabled), but tightening it removes a whole class of noise from logs.
admin_ip_cidrs = ["0.0.0.0/0"]

# Set true once you've put Caddy/nginx on the box with a valid cert for
# api.cloakvpn.ai. Until then, cloakvpn-api should stay on 127.0.0.1:8080.
enable_api_port = false
