---
/**
 * Privacy page — placeholder.
 * Phase 3 will port the full content from website/privacy.html into a
 * design-system-matching Astro template with the same legal text but
 * presented with the new Lattice visual identity. For now this stub
 * keeps the navigation working and provides a clear link to the live
 * legal content.
 */
import Layout from '@/layouts/Layout.astro';
---
<Layout title="Privacy" description="Lattice VPN privacy information.">
  <div class="pt-32 pb-16 mx-auto max-w-2xl px-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full holo-glass px-4 py-1.5 text-xs font-mono text-mint-400 mb-6">
      PHASE 3
    </span>
    <h1 class="font-display font-bold text-4xl text-white mb-4">Privacy</h1>
    <p class="text-slate-400 mb-8">
      This page is being rebuilt with the new design system. Full content lives at the legacy URL while we finish the redesign.
    </p>
    <a href="https://cloakvpn.ai/privacy" class="inline-flex items-center gap-2 rounded-full holo-glass-strong text-white font-medium text-sm px-6 py-3 hover:border-mint-500/40 transition-all">
      Read current privacy page
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
    </a>
  </div>
</Layout>
