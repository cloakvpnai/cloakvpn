---
/**
 * Terms page — placeholder.
 * Phase 3 will port the full content from website/terms.html into a
 * design-system-matching Astro template with the same legal text but
 * presented with the new Lattice visual identity. For now this stub
 * keeps the navigation working and provides a clear link to the live
 * legal content.
 */
import Layout from '@/layouts/Layout.astro';
---
<Layout bare title="Terms" description="Lattice VPN terms information.">
  <div class="pt-32 pb-16 mx-auto max-w-2xl px-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 border border-slate-200 px-3 py-1 text-xs font-semibold tracking-wide text-slate-600 mb-6">
      PHASE 3
    </span>
    <h1 class="font-display font-extrabold text-4xl tracking-tight text-slate-900 mb-4">Terms</h1>
    <p class="text-slate-600 mb-8">
      This page is being rebuilt with the new design system. Full content lives at the legacy URL while we finish the redesign.
    </p>
    <a href="https://cloakvpn.ai/terms" class="inline-flex items-center gap-2 rounded-full bg-slate-900 hover:bg-slate-800 text-white font-semibold text-sm px-6 py-3 transition-colors">
      Read current terms page
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
    </a>
  </div>
</Layout>
