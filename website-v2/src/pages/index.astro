---
/**
 * Home page — light theme commercial VPN layout.
 *
 * Structure modeled on the conversion patterns used by ExpressVPN,
 * NordVPN, PrivateInternetAccess: bold hero with IP-detection card,
 * platforms grid, features, pricing teaser, footer. White background,
 * brand colors as accents only.
 */
import Layout from '@/layouts/Layout.astro';
import LatticeHero from '@/components/LatticeHero.astro';
import Platforms from '@/components/Platforms.astro';
import Features from '@/components/Features.astro';
---

<Layout title="home" description="Lattice VPN — post-quantum encryption for iPhone. See your current IP and protect your connection in one tap.">
  <LatticeHero />
  <Platforms />
  <Features />

  <!-- Pricing teaser -->
  <section class="relative py-20 bg-slate-50/60 border-y border-slate-200">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <span class="inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 mb-4 reveal">
        SIMPLE PRICING
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 reveal" style="transition-delay: 80ms;">
        Two plans. <span class="text-mint-600">Zero logs.</span>
      </h2>
      <p class="mt-3 text-slate-600 max-w-xl mx-auto reveal" style="transition-delay: 160ms;">
        Starting at $4.99/month. Cancel anytime from your Apple ID subscriptions.
      </p>

      <div class="mt-8 grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <div class="soft-card rounded-2xl p-6 text-left reveal" style="transition-delay: 220ms;">
          <p class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-2">Basic</p>
          <p class="font-display text-3xl font-extrabold text-slate-900">$4.99<span class="text-base font-medium text-slate-500">/mo</span></p>
          <p class="text-sm text-slate-500 mt-1">or $50/year &mdash; save 17%</p>
        </div>
        <div class="soft-card rounded-2xl p-6 text-left ring-2 ring-mint-500/40 reveal" style="transition-delay: 280ms;">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">Pro</p>
            <span class="inline-flex items-center rounded-full bg-mint-500/10 text-mint-700 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider">Most popular</span>
          </div>
          <p class="font-display text-3xl font-extrabold text-slate-900">$9.99<span class="text-base font-medium text-slate-500">/mo</span></p>
          <p class="text-sm text-slate-500 mt-1">or $90/year &mdash; save 25%</p>
        </div>
      </div>

      <a
        href="/pricing"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-slate-900 hover:bg-slate-800 text-white font-semibold text-sm px-6 py-3 transition-colors reveal"
        style="transition-delay: 340ms;"
      >
        See full pricing &amp; features
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
