---
/**
 * Pricing page.
 *
 * Two plans (Basic / Pro), two billing intervals (Monthly / Yearly).
 * Yearly is selected by default — the annual discount is the headline.
 *
 * Sold via Stripe Payment Links — the no-account model (see
 * docs/BILLING_INTEGRATION.md). Paying generates an account number the
 * customer enters in the app; there is no email/password signup. After
 * checkout Stripe redirects to /welcome, which shows the number.
 *
 * Prices (docs/PRICING.md):
 *   Basic — $4.99/mo or $49.99/yr   (2 months free)
 *   Pro   — $9.99/mo or $99.99/yr   (2 months free)
 *
 * The four live buy.stripe.com Payment Link URLs, created in the Stripe
 * Dashboard (docs/STRIPE_SETUP.md). Each redirects to /welcome.
 */
import Layout from '@/layouts/Layout.astro';

const PAYMENT_LINKS = {
  basicMonthly: 'https://buy.stripe.com/9B600j83jfwo3Xv2SwfrW00',
  basicYearly: 'https://buy.stripe.com/bJeeVdcjz98051zfFifrW01',
  proMonthly: 'https://buy.stripe.com/bJefZh1EVgAs79H9gUfrW02',
  proYearly: 'https://buy.stripe.com/8x26oHcjz0Budy53WAfrW03',
};

const plans = [
  {
    name: 'Basic',
    tagline: 'Post-quantum privacy for everyday use.',
    monthly: 4.99,
    yearly: 49.99,
    monthlyLink: PAYMENT_LINKS.basicMonthly,
    yearlyLink: PAYMENT_LINKS.basicYearly,
    features: [
      '3 devices',
      'US server (more regions soon)',
      'Post-quantum encryption',
      'No-logs guarantee',
      'Kill switch',
      'Email support',
    ],
    highlight: false,
  },
  {
    name: 'Pro',
    tagline: 'For users who need more.',
    monthly: 9.99,
    yearly: 99.99,
    monthlyLink: PAYMENT_LINKS.proMonthly,
    yearlyLink: PAYMENT_LINKS.proYearly,
    features: [
      'Up to 10 devices',
      'US server (more regions soon)',
      'Post-quantum encryption',
      'No-logs guarantee',
      'Kill switch',
      'Priority email support',
      'Custom region (coming soon)',
      'Pro app icon variant',
    ],
    highlight: true,
  },
];
---

<Layout title="Pricing" description="Two plans for Lattice VPN. Basic from $4.99/month, Pro from $9.99/month. Yearly billing gives you two months free.">
  <div class="pt-32 pb-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 border border-slate-200 px-3 py-1 text-xs font-semibold tracking-wide text-slate-600 mb-6">
          PRICING
        </span>
        <h1 class="font-display font-extrabold text-5xl md:text-6xl tracking-tight leading-tight text-slate-900">
          One VPN. Two plans.
          <br />
          <span class="text-mint-600">Zero logs.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-600 max-w-xl mx-auto">
          No account, no email — pay and you get an account number to use in the app. Yearly plans give you two months free.
        </p>
      </div>

      <!-- Billing interval toggle -->
      <div class="flex justify-center mb-12">
        <div class="inline-flex items-center bg-slate-100 border border-slate-200 rounded-full p-1.5 text-sm">
          <button type="button" data-interval="monthly" class="rounded-full px-5 py-2 font-medium transition-colors text-slate-600 hover:text-slate-900" data-billing-toggle>
            Monthly
          </button>
          <button type="button" data-interval="yearly" class="rounded-full px-5 py-2 font-medium transition-colors bg-mint-500 text-slate-900 hover:text-slate-900" data-billing-toggle data-active>
            Yearly
            <span class="ml-1.5 text-xs font-mono opacity-80">2 months free</span>
          </button>
        </div>
      </div>

      <!-- Plan cards -->
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {plans.map((plan) => (
          <div
            class:list={[
              'relative rounded-2xl p-8 flex flex-col soft-card',
              plan.highlight && 'ring-2 ring-mint-500/40',
            ]}
          >
            {plan.highlight && (
              <span class="absolute -top-3 left-8 inline-flex items-center gap-2 rounded-full bg-mint-500 text-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-wider">
                Most popular
              </span>
            )}

            <h3 class="font-display font-bold text-2xl text-slate-900 mb-1">{plan.name}</h3>
            <p class="text-sm text-slate-600 mb-6">{plan.tagline}</p>

            <div class="mb-6">
              <span class="font-display font-bold text-5xl text-slate-900">
                <span data-price-display>${plan.yearly}</span>
                <span class="text-xl text-slate-500 font-medium" data-suffix-yearly>/year</span>
                <span class="text-xl text-slate-500 font-medium hidden" data-suffix-monthly>/month</span>
              </span>
              <p class="text-xs text-slate-500 mt-2 font-mono" data-effective-monthly>
                ${(plan.yearly / 12).toFixed(2)}/mo billed annually
              </p>
            </div>

            <ul class="space-y-3 mb-8 flex-grow">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3FCFA0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={plan.yearlyLink}
              class:list={[
                'inline-flex items-center justify-center gap-2 rounded-full font-semibold text-sm px-5 py-3 transition-colors',
                plan.highlight
                  ? 'bg-mint-500 hover:bg-mint-600 text-slate-900'
                  : 'bg-slate-900 hover:bg-slate-800 text-white',
              ]}
              data-monthly-price={plan.monthly}
              data-yearly-price={plan.yearly}
              data-monthly-link={plan.monthlyLink}
              data-yearly-link={plan.yearlyLink}
            >
              Get {plan.name}
            </a>
          </div>
        ))}
      </div>

      <!-- Footnote -->
      <p class="mt-10 text-center text-xs text-slate-500 font-mono">
        Subscriptions auto-renew. Manage or cancel anytime from your billing portal. Lost your account number? Recover it at <a href="/recover" class="text-mint-700 underline">latticevpn.ai/recover</a>.
      </p>
    </div>
  </div>

  <script>
    // Toggle between Monthly and Yearly billing — updates the displayed
    // price AND the Stripe Payment Link each "Get …" button points at.
    const buttons = document.querySelectorAll<HTMLElement>('[data-billing-toggle]');
    const updatePrices = (interval: 'monthly' | 'yearly') => {
      buttons.forEach((b) => {
        const active = b.dataset.interval === interval;
        b.classList.toggle('bg-mint-500', active);
        b.classList.toggle('text-slate-900', active);
        b.classList.toggle('text-slate-600', !active);
        if (active) b.setAttribute('data-active', '');
        else b.removeAttribute('data-active');
      });

      document.querySelectorAll<HTMLElement>('[data-monthly-price]').forEach((cta) => {
        const card = cta.closest('.soft-card') as HTMLElement;
        const priceDisplay = card?.querySelector('[data-price-display]');
        const suffixY = card?.querySelector('[data-suffix-yearly]');
        const suffixM = card?.querySelector('[data-suffix-monthly]');
        const effective = card?.querySelector('[data-effective-monthly]');
        const monthly = parseFloat(cta.dataset.monthlyPrice || '0');
        const yearly = parseFloat(cta.dataset.yearlyPrice || '0');

        if (interval === 'yearly') {
          if (priceDisplay) priceDisplay.textContent = `$${yearly}`;
          suffixY?.classList.remove('hidden');
          suffixM?.classList.add('hidden');
          if (effective) effective.textContent = `$${(yearly / 12).toFixed(2)}/mo billed annually`;
          cta.setAttribute('href', cta.dataset.yearlyLink || '#');
        } else {
          if (priceDisplay) priceDisplay.textContent = `$${monthly}`;
          suffixY?.classList.add('hidden');
          suffixM?.classList.remove('hidden');
          if (effective) effective.textContent = `Save $${((monthly * 12) - yearly).toFixed(2)} with annual`;
          cta.setAttribute('href', cta.dataset.monthlyLink || '#');
        }
      });
    };

    buttons.forEach((b) => {
      b.addEventListener('click', () => updatePrices(b.dataset.interval as 'monthly' | 'yearly'));
    });
  </script>
</Layout>
