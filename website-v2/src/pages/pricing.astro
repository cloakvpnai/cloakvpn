---
/**
 * Pricing page.
 *
 * Two plans (Basic / Pro), two billing intervals (Monthly / Yearly).
 * Yearly tab is selected by default — most VPN sites do this since the
 * yearly discount is the headline.
 *
 * Prices per user spec:
 *   Basic — $4.99/mo or $50/yr  (~17% yearly discount)
 *   Pro   — $9.99/mo or $90/yr  (~25% yearly discount)
 *
 * In-App-Purchase via Apple is the path for end users. Direct Stripe
 * links are kept as a fallback for non-iOS visitors but are Phase B
 * (post-Apple-approval) work.
 */
import Layout from '@/layouts/Layout.astro';

const plans = [
  {
    name: 'Basic',
    tagline: 'Personal privacy on one device.',
    monthly: 4.99,
    yearly: 50,
    features: [
      '1 device',
      'All 4 region servers',
      'Post-quantum encryption',
      'No-logs guarantee',
      'Kill switch',
      'Email support',
    ],
    highlight: false,
  },
  {
    name: 'Pro',
    tagline: 'For users who need more.',
    monthly: 9.99,
    yearly: 90,
    features: [
      'Up to 5 devices',
      'All 4 region servers',
      'Post-quantum encryption',
      'No-logs guarantee',
      'Kill switch',
      'Priority email support',
      'Custom region (coming soon)',
      'Pro app icon variant',
    ],
    highlight: true,
  },
];
---

<Layout title="Pricing" description="Two plans for Lattice VPN. Basic from $4.99/month, Pro from $9.99/month. Yearly billing saves up to 25%.">
  <div class="pt-32 pb-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 rounded-full holo-glass px-4 py-1.5 text-xs font-mono text-mint-400 mb-6">
          PRICING
        </span>
        <h1 class="font-display font-bold text-5xl md:text-6xl tracking-tight leading-tight text-white">
          One VPN. Two plans.
          <br />
          <span class="text-gradient-mint-amber">Zero logs.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-300 max-w-xl mx-auto">
          Cancel anytime from your Apple ID subscriptions. Yearly plans save up to 25%.
        </p>
      </div>

      <!-- Billing interval toggle -->
      <div class="flex justify-center mb-12">
        <div class="inline-flex items-center holo-glass rounded-full p-1.5 text-sm">
          <button type="button" data-interval="monthly" class="rounded-full px-5 py-2 font-medium transition-colors text-slate-300 hover:text-white" data-billing-toggle>
            Monthly
          </button>
          <button type="button" data-interval="yearly" class="rounded-full px-5 py-2 font-medium transition-colors bg-mint-500 text-navy-900" data-billing-toggle data-active>
            Yearly
            <span class="ml-1.5 text-xs font-mono opacity-80">Save 25%</span>
          </button>
        </div>
      </div>

      <!-- Plan cards -->
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {plans.map((plan) => (
          <div
            class:list={[
              'relative rounded-2xl p-8 flex flex-col',
              plan.highlight ? 'holo-glass-strong border-mint-500/40' : 'holo-glass',
            ]}
          >
            {plan.highlight && (
              <span class="absolute -top-3 left-8 inline-flex items-center gap-2 rounded-full bg-mint-500 text-navy-900 px-3 py-1 text-xs font-semibold uppercase tracking-wider">
                Most popular
              </span>
            )}

            <h3 class="font-display font-bold text-2xl text-white mb-1">{plan.name}</h3>
            <p class="text-sm text-slate-400 mb-6">{plan.tagline}</p>

            <div class="mb-6">
              <span class="font-display font-bold text-5xl text-white">
                <span data-price-display>${plan.yearly}</span>
                <span class="text-xl text-slate-500 font-medium" data-suffix-yearly>/year</span>
                <span class="text-xl text-slate-500 font-medium hidden" data-suffix-monthly>/month</span>
              </span>
              <p class="text-xs text-slate-500 mt-2 font-mono" data-effective-monthly>
                ${(plan.yearly / 12).toFixed(2)}/mo billed annually
              </p>
            </div>

            <ul class="space-y-3 mb-8 flex-grow">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-slate-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5FE3B5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href="https://apps.apple.com/app/lattice-vpn/id6764261045"
              class:list={[
                'inline-flex items-center justify-center gap-2 rounded-full font-semibold text-sm px-5 py-3 transition-all',
                plan.highlight
                  ? 'bg-mint-500 hover:bg-mint-400 text-navy-900 shadow-[0_0_24px_rgba(95,227,181,0.4)]'
                  : 'holo-glass-strong text-white hover:border-mint-500/40',
              ]}
              target="_blank"
              rel="noopener"
              data-monthly-price={plan.monthly}
              data-yearly-price={plan.yearly}
            >
              Get {plan.name}
            </a>
          </div>
        ))}
      </div>

      <!-- Comparison footnote -->
      <p class="mt-10 text-center text-xs text-slate-500 font-mono">
        Subscriptions auto-renew. Manage or cancel anytime in your iPhone Settings &rarr; Apple ID &rarr; Subscriptions.
      </p>
    </div>
  </div>

  <script>
    // Toggle between Monthly and Yearly billing
    const buttons = document.querySelectorAll<HTMLElement>('[data-billing-toggle]');
    const updatePrices = (interval: 'monthly' | 'yearly') => {
      // Toggle button active state
      buttons.forEach((b) => {
        const active = b.dataset.interval === interval;
        b.classList.toggle('bg-mint-500', active);
        b.classList.toggle('text-navy-900', active);
        b.classList.toggle('text-slate-300', !active);
        if (active) b.setAttribute('data-active', '');
        else b.removeAttribute('data-active');
      });

      // Update each plan card
      document.querySelectorAll<HTMLElement>('[data-monthly-price]').forEach((cta) => {
        const card = cta.closest('.holo-glass, .holo-glass-strong') as HTMLElement;
        const priceDisplay = card?.querySelector('[data-price-display]');
        const suffixY = card?.querySelector('[data-suffix-yearly]');
        const suffixM = card?.querySelector('[data-suffix-monthly]');
        const effective = card?.querySelector('[data-effective-monthly]');
        const monthly = parseFloat(cta.dataset.monthlyPrice || '0');
        const yearly = parseFloat(cta.dataset.yearlyPrice || '0');

        if (interval === 'yearly') {
          if (priceDisplay) priceDisplay.textContent = `$${yearly}`;
          suffixY?.classList.remove('hidden');
          suffixM?.classList.add('hidden');
          if (effective) effective.textContent = `$${(yearly / 12).toFixed(2)}/mo billed annually`;
        } else {
          if (priceDisplay) priceDisplay.textContent = `$${monthly}`;
          suffixY?.classList.add('hidden');
          suffixM?.classList.remove('hidden');
          if (effective) effective.textContent = `Save $${((monthly * 12) - yearly).toFixed(2)} with annual`;
        }
      });
    };

    buttons.forEach((b) => {
      b.addEventListener('click', () => updatePrices(b.dataset.interval as 'monthly' | 'yearly'));
    });
  </script>
</Layout>
