---
/**
 * Closing CTA before footer.
 *
 * Big centered card with gradient backdrop, single primary CTA (App Store)
 * and a "What you get" microscript above to keep momentum. Reinforces the
 * three core promises one last time before the footer.
 */
---

<section class="relative py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="relative reveal rounded-3xl overflow-hidden">
      <!-- Background layers -->
      <div class="absolute inset-0" style="background:
        radial-gradient(ellipse 800px 400px at 50% 0%, rgba(95, 227, 181, 0.25), transparent 60%),
        radial-gradient(ellipse 800px 400px at 50% 100%, rgba(255, 179, 71, 0.15), transparent 60%),
        linear-gradient(135deg, #0E1F3A 0%, #0A1628 100%);"></div>

      <!-- Subtle moving grid pattern -->
      <div class="absolute inset-0 opacity-30" style="
        background-image:
          linear-gradient(to right, rgba(95, 227, 181, 0.07) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(95, 227, 181, 0.07) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: radial-gradient(ellipse 600px 400px at center, black 0%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse 600px 400px at center, black 0%, transparent 80%);
      "></div>

      <!-- Content -->
      <div class="relative px-8 md:px-16 py-20 text-center">
        <span class="inline-flex items-center gap-2 rounded-full holo-glass-strong px-4 py-1.5 text-xs font-mono text-mint-400 mb-8">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-mint-500 animate-pulse"></span>
          AVAILABLE NOW ON IPHONE
        </span>

        <h2 class="font-display font-bold text-4xl md:text-6xl text-white tracking-tight leading-tight">
          The privacy you deserve.
          <br />
          <span class="text-gradient-mint-amber">The math that lasts.</span>
        </h2>

        <p class="mt-6 text-lg text-slate-300 max-w-xl mx-auto">
          Free to download. Subscribe in-app from $4.99/month. Cancel anytime in iPhone settings.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href="https://apps.apple.com/app/lattice-vpn/id6764261045"
            class="inline-flex items-center justify-center gap-3 rounded-full bg-mint-500 hover:bg-mint-400 active:bg-mint-600 text-navy-900 font-semibold text-base px-8 py-4 transition-all shadow-[0_0_40px_rgba(95,227,181,0.5)] hover:shadow-[0_0_60px_rgba(95,227,181,0.7)] hover:-translate-y-0.5"
            target="_blank"
            rel="noopener"
          >
            <svg width="20" height="22" viewBox="0 0 14 16" fill="currentColor" aria-hidden="true">
              <path d="M11.36 8.5c0-1.86 1.52-2.75 1.59-2.79-.87-1.27-2.22-1.44-2.69-1.46-1.14-.12-2.24.67-2.82.67-.59 0-1.48-.66-2.44-.64-1.25.02-2.42.74-3.07 1.86-1.32 2.29-.33 5.66.94 7.51.63.91 1.36 1.93 2.32 1.89.93-.04 1.28-.6 2.4-.6 1.12 0 1.43.6 2.41.58 1-.02 1.62-.92 2.22-1.84.71-1.06.99-2.09 1.01-2.14-.02-.01-1.93-.74-1.94-2.94zM9.4 3.6c.5-.62.85-1.46.75-2.31-.73.03-1.62.48-2.15 1.1-.47.54-.89 1.41-.78 2.24.83.07 1.67-.42 2.18-1.03z" />
            </svg>
            Download on the App Store
          </a>

          <a
            href="/pricing"
            class="text-sm font-medium text-slate-300 hover:text-mint-400 transition-colors underline underline-offset-4"
          >
            See plans &rarr;
          </a>
        </div>

        <!-- Trust microcopy -->
        <div class="mt-12 flex flex-wrap justify-center items-center gap-x-8 gap-y-3 text-xs font-mono text-slate-400">
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5FE3B5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            No accounts
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5FE3B5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            No tracking
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5FE3B5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            No logs
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5FE3B5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            Cancel anytime
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
