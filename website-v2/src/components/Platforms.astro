---
/**
 * Platforms grid section.
 *
 * Active near-term roadmap only: iPhone/iPad is live today, macOS and
 * Android are in active development. We deliberately exclude Windows,
 * Linux, and the browser extensions (Chrome/Firefox/Opera) from this
 * page until they're far enough along that we can give a real date —
 * promising "coming soon" for things that won't ship for many months
 * erodes trust more than just not listing them.
 *
 * Excluded from scope per product owner: consoles, routers, smart TVs.
 */
const platforms = [
  {
    name: 'iPhone / iPad',
    slug: 'ios',
    status: 'available',
    cta: 'Download',
    href: 'https://apps.apple.com/app/lattice-vpn/id6764261045',
    icon: 'apple',
  },
  { name: 'macOS', slug: 'macos', status: 'coming-soon', icon: 'apple' },
  { name: 'Android', slug: 'android', status: 'coming-soon', icon: 'android' },
];

// Inline SVG paths for each icon (24x24 viewBox, single-color stroke or fill)
const iconSvg: Record<string, string> = {
  apple: '<path fill="currentColor" d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.08l.01-.01zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>',
  android: '<path fill="currentColor" d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48C13.85 1.23 12.95 1 12 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31C6.97 3.26 6 5.01 6 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/>',
};
---

<section id="platforms" class="relative py-24 bg-slate-50/50">
  <div class="mx-auto max-w-6xl px-6">

    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 mb-4 reveal">
        APPS &amp; PLATFORMS
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 reveal" style="transition-delay: 80ms;">
        Protect every device.
      </h2>
      <p class="mt-3 text-slate-600 max-w-xl mx-auto reveal" style="transition-delay: 160ms;">
        iPhone is live today. macOS and Android are next on the roadmap.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {platforms.map((p, i) => {
        const isAvailable = p.status === 'available';
        return (
          <div
            class:list={[
              'soft-card rounded-2xl p-5 flex flex-col items-center text-center transition-all reveal',
              isAvailable ? 'soft-card-hover ring-2 ring-mint-500/40' : 'opacity-90',
            ]}
            style={`transition-delay: ${i * 60}ms;`}
          >
            <div
              class:list={[
                'w-12 h-12 rounded-xl flex items-center justify-center mb-3',
                isAvailable ? 'bg-mint-500/10 text-mint-600' : 'bg-slate-100 text-slate-500',
              ]}
            >
              <svg width="26" height="26" viewBox="0 0 24 24" set:html={iconSvg[p.icon] || ''} />
            </div>

            <p class="text-sm font-semibold text-slate-900 mb-1">{p.name}</p>

            {isAvailable ? (
              <a
                href={p.href}
                target="_blank" rel="noopener"
                class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-mint-700 hover:text-mint-800 transition-colors"
              >
                {p.cta}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            ) : (
              <span class="mt-2 inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-amber-700">
                Coming soon
              </span>
            )}
          </div>
        );
      })}
    </div>

    <p class="mt-10 text-center text-sm text-slate-500 reveal">
      One subscription &middot; All your devices &middot; No per-device fees
    </p>
  </div>
</section>
