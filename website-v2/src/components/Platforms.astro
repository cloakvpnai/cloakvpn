---
/**
 * Platforms grid section.
 *
 * Shows the platforms we plan to support. Only iOS currently has a live
 * app (the one approved through the App Store). The rest are marked as
 * "Coming Soon" with a planned rollout — honest about roadmap, doesn't
 * mislead visitors. Excluded from scope per product owner: consoles,
 * routers, smart TVs.
 */
const platforms = [
  {
    name: 'iPhone / iPad',
    slug: 'ios',
    status: 'available',
    cta: 'Download',
    href: 'https://apps.apple.com/app/lattice-vpn/id6764261045',
    icon: 'apple',
  },
  { name: 'macOS', slug: 'macos', status: 'coming-soon', icon: 'apple' },
  { name: 'Windows', slug: 'windows', status: 'coming-soon', icon: 'windows' },
  { name: 'Android', slug: 'android', status: 'coming-soon', icon: 'android' },
  { name: 'Linux', slug: 'linux', status: 'coming-soon', icon: 'linux' },
  { name: 'Chrome', slug: 'chrome', status: 'coming-soon', icon: 'chrome' },
  { name: 'Firefox', slug: 'firefox', status: 'coming-soon', icon: 'firefox' },
  { name: 'Opera', slug: 'opera', status: 'coming-soon', icon: 'opera' },
