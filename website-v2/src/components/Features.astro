---
/**
 * Features section — light theme.
 * Six trust signals in a 3-column grid. Soft cards with mint/amber icon
 * accents. Matches the conversion-tested format of commercial VPN sites.
 */
const features = [
  { icon: 'shield', color: 'mint', title: 'Post-quantum encryption',
    body: "Lattice uses cryptography quantum computers can't break, while every other VPN uses encryption that will fall." },
  { icon: 'eye',    color: 'mint', title: 'Strict no-logs policy',
    body: 'We literally cannot hand over data we never recorded. No connection times, no IPs, no DNS queries.' },
  { icon: 'globe',  color: 'amber', title: 'Servers worldwide',
    body: 'Connect from the US, Germany, or Finland with one tap. Unlimited bandwidth, no speed throttling.' },
  { icon: 'zap',    color: 'amber', title: 'Lightning-fast WireGuard',
    body: 'Modern protocol with minimal overhead. Connect in under a second. No noticeable speed loss.' },
  { icon: 'lock',   color: 'mint', title: 'Built-in kill switch',
    body: "If the VPN drops, the network drops. Your real IP never leaks — not for a single packet." },
  { icon: 'file',   color: 'mint', title: 'Verifiable transparency',
    body: 'Public security audits, weekly warrant canary, quarterly transparency reports. We back our claims.' },
];

const iconPaths: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  eye:    'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 15a3 3 0 100-6 3 3 0 000 6z',
  globe:  'M12 2a10 10 0 100 20 10 10 0 000-20z M2 12h20 M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z',
  zap:    'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  lock:   'M19 11H5a2 2 0 00-2 2v7a2 2 0 002 2h14a2 2 0 002-2v-7a2 2 0 00-2-2z M7 11V7a5 5 0 0110 0v4',
  file:   'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z M14 2v6h6 M16 13H8 M16 17H8',
};
---

<section class="relative py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700 mb-4 reveal">
        WHY LATTICE
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 reveal" style="transition-delay: 80ms;">
        Built for the next era of privacy.
      </h2>
      <p class="mt-3 text-slate-600 max-w-2xl mx-auto reveal" style="transition-delay: 160ms;">
        Every feature was designed to outlive today's threats &mdash; and the surveillance that doesn't exist yet.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div class="soft-card soft-card-hover rounded-2xl p-6 reveal" style={`transition-delay: ${i * 60}ms;`}>
          <div class:list={[
            'w-11 h-11 rounded-xl flex items-center justify-center mb-4',
            f.color === 'mint' && 'bg-mint-500/10 text-mint-600',
            f.color === 'amber' && 'bg-amber-500/10 text-amber-600',
          ]}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[f.icon].split(' M').map((p, idx) => `<path d="${idx === 0 ? p : 'M' + p}" />`).join('')} />
          </div>
          <h3 class="font-semibold text-lg text-slate-900 mb-2">{f.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
